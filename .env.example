# ── Ingestion ──────────────────────────────────────────────────────────────
# Path to your Apple Health export.xml (used by: make ingest EXPORT_PATH=...)
# EXPORT_PATH=/path/to/export.xml

# ── LLM ────────────────────────────────────────────────────────────────────
# Get a free Groq key at https://console.groq.com
LLM_API_KEY=your-api-key-here

# OpenAI-compatible base URL (default: Groq)
# LLM_BASE_URL=https://api.groq.com/openai/v1

# Model name (default: llama-3.3-70b-versatile)
# LLM_MODEL=llama-3.3-70b-versatile

# ── Database ────────────────────────────────────────────────────────────────
# Path to the local DuckDB file (created by make ingest)
# TTI_DB_PATH=backend/data/health.duckdb
