# LLM configuration — Groq by default, OpenAI-compatible.
# Generate a key at https://console.groq.com/keys (or use your own provider).
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Path to your Apple Health export.xml (used by `make ingest`).
# Example: /Users/you/Downloads/apple_health_export/export.xml
EXPORT_PATH=
